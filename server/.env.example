# ─────────────────────────────────────────────────────────────────────────────
# Foundry Toolboxes demo — backend configuration
#
# Copy this file to `server/.env` and fill in the values, then run `az login`.
# `.env` is git-ignored; no secrets are committed. Auth uses your Azure identity
# (DefaultAzureCredential), so no API keys are stored here.
#
# PREREQUISITES (you provision these in Azure / Foundry):
#   1. A Microsoft Foundry project + a deployed chat model (e.g. gpt-4o).
#   2. The tools you want the toolbox to bundle, each as a project connection:
#        • Azure AI Search  — an index with your internal docs + a connection.
#        • MCP action server — e.g. the GitHub MCP server + a connection.
#        (Web Search is built in and needs no connection.)
#   3. The toolbox itself — create it once with:  uv run python create_toolbox.py
#      then paste the printed consumer endpoint into FOUNDRY_TOOLBOX_ENDPOINT.
#   4. `az login` with an identity that has access to the project + tools.
# ─────────────────────────────────────────────────────────────────────────────

# --- Foundry project + model (required) ---
# Project endpoint from the Foundry portal Overview page.
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>
# Chat model deployment name in the project (both agents use it).
FOUNDRY_MODEL=gpt-4o

# --- Toolbox consumer MCP endpoint (required for the "+ Toolbox" agent) ---
# Printed by create_toolbox.py; always serves the toolbox's default version.
FOUNDRY_TOOLBOX_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>/toolboxes/product-support-toolbox/mcp?api-version=v1

# --- Evaluations (required for the eval badges) ---
# Azure OpenAI endpoint of your Foundry resource; used by azure-ai-evaluation.
AZURE_OPENAI_ENDPOINT=https://<your-account>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Deployment used by the LLM-as-judge evaluators (defaults to FOUNDRY_MODEL).
EVAL_MODEL_DEPLOYMENT=gpt-4o

# ─────────────────────────────────────────────────────────────────────────────
# Toolbox contents — used only by create_toolbox.py (not at request time).
# Leave a tool's variables blank to omit it from the bundle.
# ─────────────────────────────────────────────────────────────────────────────
TOOLBOX_NAME=product-support-toolbox

# Azure AI Search over the internal product knowledge base.
AZURE_AI_SEARCH_CONNECTION_ID=
AZURE_AI_SEARCH_INDEX=

# MCP action server (e.g. GitHub) so the agent can take action.
TOOLBOX_MCP_SERVER_LABEL=github
TOOLBOX_MCP_SERVER_URL=
TOOLBOX_MCP_CONNECTION_ID=
